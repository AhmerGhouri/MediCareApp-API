What Certbot will do

Your current Nginx configuration:

server {
    listen 80;
    server_name api.medicarehospital.pk;

    location / {
        proxy_pass http://127.0.0.1:8000;
    }
}

will be updated automatically to something like:

server {
    listen 443 ssl http2;
    server_name api.medicarehospital.pk;

    ssl_certificate /etc/letsencrypt/live/api.medicarehospital.pk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.medicarehospital.pk/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8000;
    }
}

server {
    listen 80;
    server_name api.medicarehospital.pk;
    return 301 https://$host$request_uri;
}

You normally don't need to edit this manually.

